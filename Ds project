#include <stdio.h>
#include <stdlib.h>

#define MAX_RECENT 5
#define MAX_HISTORY 100
#define FILE_NAME "health_data.txt"

// Measurement structure
typedef struct {
    int heart_rate;
    float temperature;
} Measurement;

// Queue (Recent)
typedef struct {
    Measurement recent[MAX_RECENT];
    int front, rear, size;
} Queue;

// Stack (History)
typedef struct {
    Measurement history[MAX_HISTORY];
    int top;
} Stack;

// ---------------- INITIALIZATION ----------------
void initQueue(Queue *q) {
    q->front = 0;
    q->rear = -1;
    q->size = 0;
}

void initStack(Stack *s) {
    s->top = -1;
}

// ---------------- QUEUE ----------------
void enqueue(Queue *q, Measurement m) {
    if (q->size == MAX_RECENT) {
        q->front = (q->front + 1) % MAX_RECENT;
    } else {
        q->size++;
    }
    q->rear = (q->rear + 1) % MAX_RECENT;
    q->recent[q->rear] = m;
}

// ---------------- STACK ----------------
void push(Stack *s, Measurement m) {
    if (s->top < MAX_HISTORY - 1) {
        s->history[++(s->top)] = m;
    }
}

// ---------------- FILE HANDLING ----------------
void saveToFile(Measurement m) {
    FILE *fp = fopen(FILE_NAME, "a");
    if (fp != NULL) {
        fprintf(fp, "%d %.1f\n", m.heart_rate, m.temperature);
        fclose(fp);
    }
}

void loadFromFile(Queue *q, Stack *s) {
    FILE *fp = fopen(FILE_NAME, "r");
    if (fp == NULL) return;

    Measurement m;
    while (fscanf(fp, "%d %f", &m.heart_rate, &m.temperature) != EOF) {
        enqueue(q, m);
        push(s, m);
    }
    fclose(fp);
}

// ---------------- CORE FUNCTION ----------------
void addMeasurement(Queue *q, Stack *s) {
    Measurement m;

    printf("Enter Heart Rate: ");
    scanf("%d", &m.heart_rate);

    printf("Enter Temperature: ");
    scanf("%f", &m.temperature);

    enqueue(q, m);
    push(s, m);
    saveToFile(m);

    printf("✅ Measurement Added!\n");

    // Alerts
    if (m.heart_rate > 100)
        printf("⚠ ALERT: High Heart Rate!\n");
    else if (m.heart_rate < 60)
        printf("⚠ ALERT: Low Heart Rate!\n");

    if (m.temperature > 99.5)
        printf("⚠ ALERT: Fever Detected!\n");
}

// ---------------- DISPLAY ----------------
void printRecent(Queue *q) {
    if (q->size == 0) {
        printf("No recent data.\n");
        return;
    }

    printf("\n--- Recent Measurements ---\n");
    for (int i = 0; i < q->size; i++) {
        int index = (q->front + i) % MAX_RECENT;
        printf("Heart Rate: %d | Temp: %.1f\n",
               q->recent[index].heart_rate,
               q->recent[index].temperature);
    }
}

void printHistory(Stack *s) {
    if (s->top == -1) {
        printf("No history available.\n");
        return;
    }

    printf("\n--- Full History ---\n");
    for (int i = 0; i <= s->top; i++) {
        printf("Heart Rate: %d | Temp: %.1f\n",
               s->history[i].heart_rate,
               s->history[i].temperature);
    }
}

// ---------------- MENU ----------------
void menu() {
    printf("\n===== SMART HEALTH MONITOR =====\n");
    printf("1. Add Measurement\n");
    printf("2. View Recent Measurements\n");
    printf("3. View Full History\n");
    printf("4. Exit\n");
    printf("Enter choice: ");
}

// ---------------- MAIN ----------------
int main() {
    Queue q;
    Stack s;
    int choice;

    initQueue(&q);
    initStack(&s);

    loadFromFile(&q, &s);

    while (1) {
        menu();
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                addMeasurement(&q, &s);
                break;

            case 2:
                printRecent(&q);
                break;

            case 3:
                printHistory(&s);
                break;

            case 4:
                printf("Exiting... Thank you!\n");
                exit(0);

            default:
                printf("Invalid choice!\n");
        }
    }

    return 0;
}
